# =====================================
# JWT Authentication
# =====================================
JWT__SecretKey=YOUR_SUPER_SECRET_KEY_HERE
JWT__Issuer=https://yourapi.com
JWT__Audience=https://yourapi.com
JWT__RefreshTokenValidityInMinutes=1440

# =====================================
# Database Connection
# =====================================
ConnectionStrings__DefaultConnection=Server=localhost;Database=FinanceEdge;User Id=sa;Password=YourPassword123;TrustServerCertificate=True

# =====================================
# Rate Limiting
# =====================================
RateLimiting__GeneralPolicy__PermitLimit=100
RateLimiting__GeneralPolicy__Window=00:01:00
RateLimiting__GeneralPolicy__QueueLimit=0
RateLimiting__GeneralPolicy__QueueProcessingOrder=OldestFirst

RateLimiting__LoginPolicy__PermitLimit=5
RateLimiting__LoginPolicy__Window=00:00:30

# =====================================
# CORS
# =====================================
CORS__AllowedOrigins__0=https://localhost:4200
CORS__AllowedOrigins__1=https://financefrontend.com
CORS__AllowedOrigins__2=https://dashboard.finance.com
